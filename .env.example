# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# S3 Buckets
S3_SHELF_IMAGES_BUCKET=vyapariq-shelf-images
S3_PRESCRIPTIONS_BUCKET=vyapariq-prescriptions

# DynamoDB Tables
DYNAMODB_INVENTORY_TABLE=VyaparIQ-Inventory
DYNAMODB_ALERTS_TABLE=VyaparIQ-Alerts
DYNAMODB_ORDERS_TABLE=VyaparIQ-PurchaseOrders

# Lambda Function URLs
LAMBDA_ANALYZE_SHELF_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/
LAMBDA_CHECK_INTERACTIONS_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/
LAMBDA_GENERATE_ORDER_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=your_kb_id_here

# Application Settings
STORE_ID=STORE001
IMAGE_RETENTION_HOURS=24
ALERT_THRESHOLD_DAYS=30